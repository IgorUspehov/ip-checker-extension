{
  "manifest_version": 3,
  "name": "IP & Network Status",
  "version": "1.0",
  "description": "Shows your public IP, local IP and network status",
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "permissions": ["system.network"],
  "host_permissions": ["https://api.ipify.org/*"]
}
